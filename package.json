{
  "name": "hosting-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run src",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:lighthouse": "npx @lhci/cli@0.15.1 autorun --config=./lighthouserc.json",
    "test:all": "npm run lint && npm run test && npm run validate:templates && npm run validate:links && npm run test:e2e && npm run test:lighthouse && npm run build",
    "validate:templates": "node ./scripts/validate-templates.mjs",
    "validate:links": "node ./scripts/validate-links.mjs",
    "scaffold:service": "node ./scripts/scaffold-service.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.8"
  }
}
